{% extends '/Bases/StandardWebPage.html.twig' %}
{% block content %}
    <main>
        <div class="inner-content">
            <section class="overall-status-note overall-status-operational" id="overall" role="status"
                     aria-live="polite">
                <span class="note-heading" id="overall-text">Loading status...</span>
                <span class="overall-status-subheading" id="overall-sub"></span>
            </section>

            <section aria-labelledby="h-monitors">
                <h2 id="h-monitors">Last {{ GetUserConfiguration("Settings", "WindowInDays") }} days</h2>
                <div id="monitors"></div>
                <div class="uptime-legend" aria-hidden="true">
                    <span><span class="uptime-legend-swatch uptime-day-up"></span>Operational</span>
                    <span><span class="uptime-legend-swatch uptime-day-degraded"></span>Degraded</span>
                    <span><span class="uptime-legend-swatch uptime-day-down"></span>Outage</span>
                    <span><span class="uptime-legend-swatch uptime-day-nodata"></span>No data</span>
                </div>
            </section>

            <div class="status-columns">
                <div class="left-preferential-box" aria-labelledby="h-incidents">
                    <h2 id="h-incidents">Past incidents</h2>
                    <div id="incidents"></div>
                </div>

                <div class="right-preferential-box" aria-labelledby="h-maint">
                    <h2 id="h-maint">Maintenance</h2>
                    <h3 class="low-margin-heading" style="margin:0.6rem 0 0.5rem;">Scheduled</h3>
                    <div id="maint-upcoming"></div>
                    <h3 class="low-margin-heading" style="margin:1.4rem 0 0.5rem;">Past</h3>
                    <div id="maint-historical"></div>
                </div>
            </div>

            <footer>
                <div class="inner-content">
                    This page refreshes automatically every 60 seconds.
                    Times shown in <span id="tz-label">UTC</span>.
                </div>
            </footer>
        </div>
    </main>

    <script>
        "use strict";

        const STATUS_URL = "/api/v1/get-status";
        const WINDOW_DAYS = {{ GetUserConfiguration("Settings", "WindowInDays") }};
        const REFRESH_MS = {{ GetUserConfiguration("Settings", "RefreshIntervalInMilliseconds") }};

        let TZ = "UTC";

        const STATUS_LABEL = {
            up: "Operational",
            degraded: "Degraded",
            down: "Outage",
            nodata: "No data"
        };
        const STATUS_BADGE = {
            up: "positive-badge",
            degraded: "neutral-badge",
            down: "negative-badge",
            nodata: "neutral-badge"
        };

        const OVERALL_CLASS = {
            operational: "overall-status-operational",
            degraded: "overall-status-degraded",
            partial_outage: "overall-status-partial-outage",
            major_outage: "overall-status-major-outage",
            maintenance: "overall-status-maintenance"
        };
        const OVERALL_TEXT = {
            operational: "All systems operational",
            degraded: "Degraded performance",
            partial_outage: "Partial outage",
            major_outage: "Major outage",
            maintenance: "Maintenance in progress"
        };

        function el(tag, cls, text) {
            const e = document.createElement(tag);
            if (cls) e.className = cls;
            if (text != null) e.textContent = text;
            return e;
        }

        function badge(kind, text) {
            return el("span", "tag-badge-small " + kind, text);
        }

        function fmtDateTime(iso) {
            try {
                return new Date(iso).toLocaleString("en-GB",
                    {timeZone: TZ, dateStyle: "medium", timeStyle: "short", timeZoneName: "short"});
            } catch (_) {
                return iso;
            }
        }

        function fmtDate(iso) {
            try {
                return new Date(iso).toLocaleDateString("en-GB",
                    {timeZone: TZ, day: "numeric", month: "short", year: "numeric"});
            } catch (_) {
                return iso;
            }
        }

        function dayKey(date) {
            return new Intl.DateTimeFormat("en-CA",
                {timeZone: TZ, year: "numeric", month: "2-digit", day: "2-digit"}).format(date);
        }

        function durationText(aIso, bIso) {
            const ms = new Date(bIso) - new Date(aIso);
            if (!(ms > 0)) return "";
            const mins = Math.round(ms / 60000);
            if (mins < 60) return mins + " min";
            const h = Math.floor(mins / 60), m = mins % 60;
            return m ? `${h} h ${m} min` : `${h} h`;
        }

        function buildAxis() {
            const out = [], now = Date.now();
            for (let i = WINDOW_DAYS - 1; i >= 0; i--) out.push(dayKey(new Date(now - i * 86400000)));
            return out;
        }

        function monitorName(data, key) {
            return data.monitors?.[key]?.prettyName || key;
        }

        function computeOverall(data) {
            const now = Date.now();
            const maintenance = (data.maintenance?.upcoming || []).concat(data.maintenance?.historical || []);
            const activeMaintenance = maintenance.some(m => m.status === "in_progress" || (new Date(m.startsAt) <= now && now <= new Date(m.endsAt)));

            let down = 0, degraded = 0;
            for (const mon of Object.values(data.monitors || {})) {
                if (mon.currentStatus === "down") down++;
                else if (mon.currentStatus === "degraded") degraded++;
            }
            if (down > 1)
            {
                return "major_outage";
            }
            else if (down === 1)
            {
                return "partial_outage";
            }
            else if (degraded)
            {
                return "degraded";
            } else if (activeMaintenance)
            {
                return "maintenance";
            }
            return "operational";
        }

        function renderOverall(data) {
            const key = computeOverall(data);
            document.getElementById("overall").className = "overall-status-note " + OVERALL_CLASS[key];
            document.getElementById("overall-text").textContent = OVERALL_TEXT[key];
            document.getElementById("overall-sub").textContent = "Updated " + fmtDateTime(data.generatedAt || new Date().toISOString());
        }

        function renderMonitors(data) {
            const axis = buildAxis();
            const host = document.getElementById("monitors");
            host.textContent = "";

            for (const [key, mon] of Object.entries(data.monitors || {})) {
                const byDay = new Map((mon.days || []).map(d => [d.date, d]));

                const box = el("div", "status-box");
                const head = el("h4", "status-box-header");
                head.appendChild(document.createTextNode(mon.prettyName || key));
                head.appendChild(el("span", "status-box-header-spacer"));
                head.appendChild(badge(STATUS_BADGE[mon.currentStatus] || "neutral", STATUS_LABEL[mon.currentStatus] || mon.currentStatus));
                box.appendChild(head);

                const body = el("div", "status-box-body");
                if (mon.uptimeOverWindowInDays != null)
                {
                    body.appendChild(el("div", "uptime-summary", mon.uptimeOverWindowInDays.toFixed(2) + `% uptime over ${WINDOW_DAYS} days`));
                }

                const bar = el("div", "uptime-bar");
                bar.setAttribute("role", "img");
                bar.setAttribute("aria-label",
                    `${mon.prettyName || key}: ${mon.uptimeOverWindowInDays != null ? mon.uptimeOverWindowInDays.toFixed(2) + "% uptime over " : ""}the last ${WINDOW_DAYS} days`);
                for (const date of axis) {
                    const d = byDay.get(date);
                    const status = d ? d.status : "nodata";
                    const cell = el("div", "uptime-day uptime-day-" + status);
                    cell.tabIndex = 0;
                    const uptimeTxt = d && d.uptime != null ? ` - ${d.uptime}% uptime` : "";
                    cell.title = `${fmtDate(date)}: ${STATUS_LABEL[status]}${uptimeTxt}`;
                    cell.setAttribute("aria-label", cell.title);
                    bar.appendChild(cell);
                }
                body.appendChild(bar);

                const ax = el("div", "uptime-axis");
                ax.appendChild(el("span", null, `${WINDOW_DAYS} days ago`));
                ax.appendChild(el("span", null, "Today"));
                body.appendChild(ax);

                box.appendChild(body);
                host.appendChild(box);
            }
        }

        function renderIncidents(data) {
            const host = document.getElementById("incidents");
            host.textContent = "";
            const incidents = data.incidents || [];
            if (!incidents.length) {
                host.appendChild(el("p", "no-data-badge", "No incidents reported in the last 90 days."));
                return;
            }
            for (const inc of incidents) {
                const sev = (inc.impact === "major" || inc.impact === "critical") ? "status-box-negative"
                    : inc.impact === "minor" ? "status-box-neutral" : "status-box-brand";
                const box = el("div", "status-box " + sev);

                const head = el("h4", "status-box-header");
                head.appendChild(document.createTextNode(inc.title));
                head.appendChild(el("span", "status-box-header-spacer"));
                head.appendChild(badge(inc.status === "resolved" ? "positive-badge" : "neutral-badge", inc.status));
                box.appendChild(head);

                const body = el("div", "status-box-body");

                let when = (inc.impact ? inc.impact[0].toUpperCase() + inc.impact.slice(1) + " impact · " : "")
                    + "started " + fmtDateTime(inc.startedAt);
                if (inc.resolvedAt) {
                    when += " · resolved " + fmtDateTime(inc.resolvedAt);
                    const dur = durationText(inc.startedAt, inc.resolvedAt);
                    if (dur) when += ` · ${dur}`;
                } else when += " · ongoing";
                body.appendChild(el("div", "status-meta-line", when));

                const affected = (inc.affected || []).map(k => monitorName(data, k));
                if (affected.length) body.appendChild(el("div", "status-affected-line", "Affected: " + affected.join(", ")));

                const tl = el("ul", "timeline-list");
                for (const u of (inc.updates || [])) {
                    const li = el("li", "timeline-entry");
                    const line = el("div");
                    line.appendChild(el("span", "timeline-entry-time", fmtDateTime(u.postedAt)));
                    line.appendChild(el("span", "timeline-entry-title", u.status));
                    li.appendChild(line);
                    li.appendChild(el("p", "timeline-entry-description", u.body));
                    tl.appendChild(li);
                }
                body.appendChild(tl);
                box.appendChild(body);
                host.appendChild(box);
            }
        }

        function renderMaintenanceList(items, hostId, upcoming, data) {
            const host = document.getElementById(hostId);
            host.textContent = "";
            if (!items || !items.length) {
                host.appendChild(el("p", "no-data-badge",
                    upcoming ? "No maintenance scheduled." : "No past maintenance to show."));
                return;
            }
            for (const m of items) {
                const box = el("div", "status-box status-box-brand");
                const head = el("h4", "status-box-header");
                head.appendChild(document.createTextNode(m.title));
                head.appendChild(el("span", "status-box-header-spacer"));
                head.appendChild(badge(m.status === "completed" ? "positive" : "neutral",
                    m.status.replace("_", " ")));
                box.appendChild(head);

                const body = el("div", "status-box-body");
                body.appendChild(el("div", "status-meta-line",
                    `${fmtDateTime(m.startsAt)} → ${fmtDateTime(m.endsAt)} (${durationText(m.startsAt, m.endsAt)})`));
                const affected = (m.affected || []).map(k => monitorName(data, k));
                if (affected.length) body.appendChild(el("div", "status-affected-line", "Affects: " + affected.join(", ")));
                if (m.body) body.appendChild(el("p", null, m.body));

                box.appendChild(body);
                host.appendChild(box);
            }
        }

        function render(data) {
            window.__statusData = data;
            TZ = data.timezone || TZ;
            document.getElementById("tz-label").textContent = TZ;
            // document.getElementById("generated").textContent = "Updated " + fmtDateTime(data.generatedAt || new Date().toISOString());
            renderOverall(data);
            renderMonitors(data);
            renderIncidents(data);
            renderMaintenanceList(data.maintenance?.upcoming, "maint-upcoming", true, data);
            renderMaintenanceList(data.maintenance?.historical, "maint-historical", false, data);
        }

        function renderLoadFailure() {
            document.getElementById("overall").className = "overall-status-note overall-status-degraded";
            document.getElementById("overall-text").textContent = "Unable to load status";
            document.getElementById("overall-sub").textContent = "Retrying shortly...";
        }

        async function load() {
            try {
                const res = await fetch(STATUS_URL, {cache: "no-store"});
                if (!res.ok) throw new Error("HTTP " + res.status);
                render(await res.json());
            } catch (err) {
                renderLoadFailure();
            }
        }

        load();
        setInterval(load, REFRESH_MS);
    </script>
{% endblock %}

