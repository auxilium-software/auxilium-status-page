{% extends '/Bases/StandardWebPage.html.twig' %}
{% block content %}

    <main>
        <div class="inner-content">

            <div class="navigation-breadcrumb-container">
                <a href="/" class="navigation-breadcrumb"><span>{{ "Status Page"|translate }}</span></a>
                <a href="/admin" class="navigation-breadcrumb"><span>{{ "Admin Dashboard"|translate }}</span></a>
                <span class="navigation-breadcrumb"><span>{{ Maintenance.title_text }}</span></span>
            </div>

            <div class="editable-title">
                <h1>
                    {{ Maintenance.title_text }}
                    <span class="tag-badge-inline
                        {%- if Maintenance.status == 'completed' %} positive-badge
                        {%- elseif Maintenance.status == 'cancelled' %} negative-badge
                        {%- elseif Maintenance.status == 'in_progress' %} neutral-badge{% endif %}">
                        {{ Maintenance.status|replace({'_': ' '})|capitalize }}
                    </span>
                </h1>
            </div>

            {% if Errors is not empty %}
                <div class="error-toast" role="alert">
                    {% for error in Errors %}
                        <p class="no-lower-margin">{{ error }}</p>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="marked-section">
                <h3 class="low-margin-heading">{{ "Lifecycle"|translate }}</h3>
                <div class="button-box">
                    {% for status in Statuses %}
                        {% if status != Maintenance.status %}
                            <form method="post"
                                  action="/admin/maintenance/{{ Maintenance.id }}"
                                  style="display:inline-block;">
                                <input type="hidden" name="csrf_token" value="{{ CsrfToken }}">
                                <input type="hidden" name="action" value="set_status">
                                <input type="hidden" name="status" value="{{ status }}">
                                <input type="submit"
                                       class="inline-button {% if status == 'cancelled' %}dangerous-button{% endif %}"
                                       value="Mark {{ status|replace({'_': ' '}) }}">
                            </form>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>

            <div class="status-columns">
                <div class="left-preferential-box">
                    <h2>{{ "Edit plan"|translate }}</h2>

                    <form method="post" action="/admin/maintenance/{{ Maintenance.id }}">
                        <input type="hidden" name="csrf_token" value="{{ CsrfToken }}">
                        <input type="hidden" name="action" value="update">

                        <fieldset>
                            <legend>{{ "Details"|translate }}</legend>

                            <label for="title">{{ "Title"|translate }}</label>
                            <input type="text" id="title" name="title" value="{{ Maintenance.title_text }}" required>

                            <label for="body">{{ "Description"|translate }}</label>
                            <textarea id="body" name="body" rows="5" class="fullwidth-text-input" required>{{ Maintenance.body_text }}</textarea>
                        </fieldset>

                        <fieldset>
                            <legend>{{ "Window (UTC)"|translate }}</legend>

                            <label for="starts_at">{{ "Starts at"|translate }}</label>
                            <input type="datetime-local" id="starts_at" name="starts_at"
                                   value="{{ StartsAtInput }}" required>

                            <label for="ends_at">{{ "Ends at"|translate }}</label>
                            <input type="datetime-local" id="ends_at" name="ends_at"
                                   value="{{ EndsAtInput }}" required>
                        </fieldset>

                        <fieldset>
                            <legend>{{ "Affected services"|translate }}</legend>

                            {% for key, prettyName in Services %}
                                <div class="checkbox-holder">
                                    <input type="checkbox"
                                           id="affected_{{ key }}"
                                           name="affected[]"
                                           value="{{ key }}"
                                            {{ key in AffectedKeys ? 'checked' : '' }}>
                                    <label for="affected_{{ key }}"><p>{{ prettyName }}</p></label>
                                </div>
                            {% endfor %}
                        </fieldset>

                        <div class="button-box">
                            <input type="submit" value="Save changes">
                        </div>
                    </form>
                </div>

                <div class="right-preferential-box">
                    <h2>{{ "Details"|translate }}</h2>

                    <div class="marked-section">
                        <dl>
                            <dt>{{ "Window"|translate }}</dt>
                            <dd>{{ Maintenance.starts_at_utc }} -> {{ Maintenance.ends_at_utc }} UTC</dd>

                            <dt>{{ "Scheduled by"|translate }}</dt>
                            <dd>{{ Maintenance.created_by }}</dd>

                            <dt>{{ "Created"|translate }}</dt>
                            <dd>{{ Maintenance.created_at_utc }} UTC</dd>
                        </dl>
                    </div>

                    <h2>{{ "Progress notes"|translate }}</h2>

                    <form method="post" action="/admin/maintenance/{{ Maintenance.id }}">
                        <input type="hidden" name="csrf_token" value="{{ CsrfToken }}">
                        <input type="hidden" name="action" value="post_update">

                        <fieldset>
                            <legend>{{ "Post a note"|translate }}</legend>

                            <label for="update_title">{{ "Title"|translate }}</label>
                            <input type="text" id="update_title" name="update_title" placeholder="{{ "e.g. Running 20 minutes over"|translate }}">

                            <label for="update_body">{{ "Note"|translate }}</label>
                            <textarea id="update_body" name="update_body" rows="3" class="fullwidth-text-input"></textarea>

                            <input type="submit" value="{{ "Post note"|translate }}">
                        </fieldset>
                    </form>

                    {% if Updates is not empty %}
                        <ul class="timeline-list">
                            {% for update in Updates %}
                                <li class="timeline-entry">
                                    <span class="timeline-entry-time">{{ update.created_at_utc }} UTC</span>
                                    <span class="timeline-entry-title">{{ update.title_text }}</span>
                                    <span class="timeline-entry-meta">{{ update.created_by }}</span>
                                    <p class="timeline-entry-description">{{ update.body_text }}</p>
                                </li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>
            </div>
        </div>
    </main>
{% endblock %}
